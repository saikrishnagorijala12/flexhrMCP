# ── Microsoft 365 ──────────────────────────────────────────────────────────────
# Create an Azure AD app at https://portal.azure.com → App registrations
# Add a "Mobile and desktop applications" redirect URI: https://login.microsoftonline.com/common/oauth2/nativeclient
# Grant these API permissions (Delegated):
#   Microsoft Graph: User.Read, Mail.Read, Calendars.Read, Notes.Read, Chat.Read, offline_access
MS_CLIENT_ID=your-azure-app-client-id
MS_TENANT_ID=common              # or your-org-tenant-id for work accounts

# ── Frappe HRMS (FlexHR) ───────────────────────────────────────────────────────
FLEXHR_URL=https://your-company.flexhr.com
FLEXHR_USERNAME=your.email@company.com   # your own login (used only to read metadata)
FLEXHR_PASSWORD=your-password
FLEXHR_EMPLOYEE=YTP1180                  # Your employee ID in Frappe HRMS
FLEXHR_COMPANY=YottaFlex.ai             # Company name exactly as shown in the timesheet
FLEXHR_WORK_STATUS=Working From Office  # "Working From Office" or "Working From Home"

# API user for timesheet submission — needs Create permission on Timesheet doctype.
# If your own account has permission, set these to the same values as above.
# Otherwise ask your HR/IT admin to create a dedicated API user in Frappe and share these.
FLEXHR_API_USERNAME=api-user@company.com
FLEXHR_API_PASSWORD=api-user-password

# ── OpenRouter ────────────────────────────────────────────────────────────────
# Get your key from https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...
# Find model slugs at https://openrouter.ai/models (filter by Claude)
OPENROUTER_MODEL=anthropic/claude-sonnet-4-6

# ── Activity Types Override ────────────────────────────────────────────────────
# Comma-separated list that pins exactly which activity types the AI may use.
# When set, skips the API lookup entirely — use to enforce your employee's allowed types.
# (YTP1180 list — adjust if your FlexHR instance differs)
FLEXHR_ACTIVITY_TYPES=Client Coordination,Client Requirements & Solutioning,Continuous Learning and Training,Deployment & Release Management,DevOps & Cloud,Internal Meetings,Production Support,QA & Testing,Scrum & Sprint Execution,Software Development

# ── Optional ───────────────────────────────────────────────────────────────────
# MS_TOKEN_CACHE=.token_cache.json   # where to store the OAuth token cache
# TIMEZONE=Asia/Kolkata              # your local timezone (default: UTC)
#
# ── OneDrive Activity Folder (requires SharePoint Online license on tenant) ────
# ONEDRIVE_FOLDER=YTP/Timesheets

# ── Local Notes Folder ─────────────────────────────────────────────────────────
# Path to a local folder containing your daily/weekly activity notes.
# Supports .txt .md .log .docx .jpg .png and other image formats.
# Works with a locally-synced OneDrive folder or any plain directory.
# Example: NOTES_FOLDER=~/OneDrive/YTP/Timesheets
# NOTES_FOLDER=
